{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Request",
  "type": "object",
  "properties": {
    "agent_id": { "type": "string", "format": "uuid" },
    "task_id": { "type": "string", "format": "uuid" },
    "chain_id": { "type": "string", "format": "uuid" },
    "chain_version_id": { "type": "string", "format": "uuid" },
    "provider_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,63}$"
    },
    "model_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool"]
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "content": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["text"]
                    },
                    "text": { "type": "string" }
                  },
                  "required": ["type", "text"],
                  "additionalProperties": false
                }
              }
            ]
          },
          "tool_call_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        },
        "required": ["role", "content"],
        "additionalProperties": false
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "top_p": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32768
        },
        "frequency_penalty": {
          "type": "number",
          "minimum": -2,
          "maximum": 2
        },
        "presence_penalty": {
          "type": "number",
          "minimum": -2,
          "maximum": 2
        },
        "metadata": { "type": "object" }
      },
      "additionalProperties": true
    }
  },
  "required": ["provider_id", "model_id", "messages"],
  "additionalProperties": false
}
