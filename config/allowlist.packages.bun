# Allowlist: Bun packages or scripts that MCP servers are permitted to install and run.
#
# One entry per line. Exact package names or name@version are supported.
# Lines starting with # are comments and are ignored.
#
# Examples:
#   my-bun-mcp-server
#   my-bun-mcp-server@1.2.3
#
# For additional private or third-party packages, add them to allowlist.packages.bun.local
# (that file is gitignored and will be merged automatically at runtime).
