{
  "name": "ontheia-host",
  "version": "0.1.6",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "rm -rf dist && tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "test": "npm run build && node --test \"dist/**/*.spec.js\"",
    "memory:reembed": "node dist/scripts/reembed_worker.js",
    "memory:verify": "node dist/scripts/memory_verify.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "cron-parser": "^5.5.0",
    "fastify": "^5.8.4",
    "fastify-oauth2": "^4.5.0",
    "fastify-sse-v2": "^4.2.1",
    "jsonrepair": "^3.13.2",
    "node-cron": "^4.2.1",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.12.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^8.57.0",
    "pino-pretty": "^13.1.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
