# =============================================================================
# Ontheia – Environment Variables (Example)
# Copy this file to .env and adjust the values.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_ENV=production
PORT=8080
APP_TIMEZONE=Europe/Berlin

# -----------------------------------------------------------------------------
# Database
# The backend uses the restricted user ontheia_app to enforce Row Level Security.
# Flyway uses the postgres superuser for migrations.
# ONTHEIA_APP_PASSWORD: password for the ontheia_app DB role — must match in DATABASE_URL.
# The install script generates this automatically.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ontheia_app:CHANGE_ME@db:5432/ontheia
FLYWAY_URL=jdbc:postgresql://db:5432/ontheia
FLYWAY_USER=postgres
FLYWAY_PASSWORD=CHANGE_ME
ONTHEIA_APP_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# AI Provider / Embeddings
# Memory/RAG features are disabled by default and can be enabled via the Admin UI.
# Optional: set OPENAI_API_KEY here as an alternative to Admin UI configuration.
# -----------------------------------------------------------------------------
#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#XAI_API_KEY=xai-...
#GOOGLE_API_KEY=AIza...
#LOCAL_EMBEDDING_ENDPOINT=http://localhost:8001/embed
#EMBEDDING_CONFIG_PATH=./config/embedding.json

# -----------------------------------------------------------------------------
# MCP Orchestrator (Docker)
# ROOTLESS_DOCKER_HOST: Unix socket of the user's rootless Docker instance
# DOCKER_NETWORK: Docker network name for MCP containers
# REQUIRE_ROOTLESS_DOCKER: set to false only for local development
# -----------------------------------------------------------------------------
ROOTLESS_DOCKER_HOST=unix:///run/user/1000/docker.sock
DOCKER_SOCKET_PATH=/run/user/1000/docker.sock
DOCKER_NETWORK=ontheia-net
#REQUIRE_ROOTLESS_DOCKER=true
#DOCKER_BIN=docker

# Allowlist paths (relative to working directory or absolute)
ALLOWLIST_IMAGES_PATH=./config/allowlist.images
ALLOWLIST_PACKAGES_NPM_PATH=./config/allowlist.packages.npm
ALLOWLIST_PACKAGES_PYPI_PATH=./config/allowlist.packages.pypi
ALLOWLIST_PACKAGES_BUN_PATH=./config/allowlist.packages.bun
#ALLOWLIST_URLS_PATH=./config/allowlist.urls
#ORCHESTRATOR_HARDENING_PATH=./config/orchestrator.hardening.json

# -----------------------------------------------------------------------------
# CLI Provider (host paths mounted into containers)
# NVM_DIR: nvm installation of the user who owns the CLI tools
# GEMINI_CONFIG_DIR: .gemini directory with auth credentials (Google Gemini CLI)
# -----------------------------------------------------------------------------
NVM_DIR=/home/YOUR_USER/.nvm
#GEMINI_CONFIG_DIR=/home/YOUR_USER/.gemini
#CLAUDE_CONFIG_DIR=/home/YOUR_USER/.claude

# -----------------------------------------------------------------------------
# Security / Auth
# SESSION_SECRET: Random, long string — never use "change-me" in production!
# ADMIN_EMAIL: Email address of the initial admin account
# ALLOWED_ORIGINS: Comma-separated list of permitted CORS origins
# -----------------------------------------------------------------------------
SESSION_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD: Initial password for the admin account created by the bootstrap script.
# The install script generates a secure random password automatically.
# Set this only if you want to override the generated password.
#ADMIN_PASSWORD=CHANGE_ME
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
#LOG_LEVEL=info
#LOG_FILE=./host_server.log
#LOG_MAX_BYTES=10485760
#LOG_MAX_FILES=5
#PINO_PRETTY=false

# -----------------------------------------------------------------------------
# WebUI (Vite build-time)
# VITE_HOST_API_URL: URL of the host backend as seen by the browser
# -----------------------------------------------------------------------------
VITE_HOST_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# System Chains (UUIDs from the database)
# Set after initial setup via the Admin UI.
# -----------------------------------------------------------------------------
PROMPT_OPTIMIZER_CHAIN_ID=cd08ffb9-d60c-4512-a364-1b19390f3af0
VITE_PROMPT_OPTIMIZER_CHAIN_ID=cd08ffb9-d60c-4512-a364-1b19390f3af0

# -----------------------------------------------------------------------------
# MCP Host – Timeouts
# -----------------------------------------------------------------------------
MCP_CLIENT_CONNECT_TIMEOUT_MS=60000

# -----------------------------------------------------------------------------
# MCP Server – Mail (optional, only needed when using the mail MCP server)
# -----------------------------------------------------------------------------
#MAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Debug (development only — never enable in production!)
# -----------------------------------------------------------------------------
#DEBUG_CHATS=false
#DEBUG_TOOLS=false
